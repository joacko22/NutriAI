# ─── Database ────────────────────────────────────────────────────────────────
# Railway provee esta variable automáticamente si agregás un servicio PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Redis ───────────────────────────────────────────────────────────────────
# Railway provee esta variable automáticamente si agregás un servicio Redis
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generá tus propios secretos con:
# node -e "const c=require('crypto');console.log(c.randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="tu-secreto-de-64-bytes-en-hex"
JWT_REFRESH_SECRET="otro-secreto-de-64-bytes-en-hex"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Crear credenciales en: console.cloud.google.com
# Agregar redirect URI: https://tu-dominio.railway.app/api/v1/auth/google/callback
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-tu-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ─── AI Providers (al menos uno requerido) ───────────────────────────────────
# Gemini: aistudio.google.com/app/apikey
GEMINI_API_KEY="tu-gemini-api-key"
# Groq: console.groq.com/keys
GROQ_API_KEY="gsk_tu-groq-api-key"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
CLIENT_URL="https://tu-app-web.vercel.app"
