# ─── Database ────────────────────────────────────────────────────────────────
# Railway: copy the DATABASE_URL from the PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Redis ───────────────────────────────────────────────────────────────────
# Railway: copy from the Redis plugin, or use an Upstash URL
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "const c=require('crypto');console.log(c.randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at: console.cloud.google.com
# Authorized redirect URI (production): https://<your-api-domain>/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ─── AI Providers (at least one required) ────────────────────────────────────
# Gemini (primary):  aistudio.google.com/app/apikey  — free, 1500 req/day
GEMINI_API_KEY=""
# Groq (fallback):   console.groq.com/keys           — free
GROQ_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Production: set to your deployed web URL (e.g. https://nutriai.vercel.app)
CLIENT_URL="http://localhost:5173"
